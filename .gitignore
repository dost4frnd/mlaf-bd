# Python
__pycache__/
*.pyc

# Local datasets (large; staged from mirrors / re-fetched by the run scripts).
# See REPRODUCE.md for how to restage MNIST + CIFAR-10.
data/

# Model checkpoints (large; produced by the run scripts with --save-ckpt).
checkpoints/
*.pt

# LaTeX build artifacts (regenerated by `make paper`).
paper/*.aux
paper/*.log
paper/*.out
paper/*.bbl
paper/*.blg
paper/*.synctex.gz

# Local run-harness scratch (resumable driver, staging, logs, resume notes).
# These drive experiments but are not part of the published artifact.
_*.py
_*.sh
_*.log
_RESUME_STATE.md

# Misc
*.zip
.DS_Store

# Note: results/*.npz (small figure-source arrays) and paper/main.pdf are kept
# in the repo so figures/tables and the built paper reproduce without a GPU run.
